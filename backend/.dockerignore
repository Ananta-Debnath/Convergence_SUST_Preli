# Build context hygiene for the backend image.
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Secrets — never bake into an image.
.env
.env.*
!.env.example

# VCS + editor + OS junk
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store
Thumbs.db

# Docker self-references (we COPY explicitly above)
Dockerfile
Dockerfile.*
.dockerignore

# Docs, tests, coverage — not needed at runtime
*.md
README.md
coverage
.nyc_output

# Puku / local tooling
.puku